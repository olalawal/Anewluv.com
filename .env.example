# Netlify and service credentials stay local/CI only.
# Do not commit real values.
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# Server-side only. Used by Netlify Functions; never expose through VITE_.
ANEWLUV_APP_BASE_URL=
ANEWLUV_XANO_AUTH_API_BASE_URL=https://YOUR-XANO-INSTANCE.example/path/to/auth-api
ANEWLUV_XANO_CONTACT_API_BASE_URL=https://YOUR-XANO-INSTANCE.example/path/to/contact-api
ANEWLUV_XANO_DISCOVER_API_BASE_URL=https://YOUR-XANO-INSTANCE.example/path/to/discover-api
ANEWLUV_PROFILE_EDIT_API_BASE_URL=https://YOUR-XANO-INSTANCE.example/path/to/profile-api
ANEWLUV_SITE_DISCOVER_ACCESS_CREDENTIAL=
ANEWLUV_SITE_PREVIEW_ACCOUNT_EMAIL=
ANEWLUV_SITE_PREVIEW_ACCOUNT_EMAILS=
ANEWLUV_SITE_PREVIEW_ACCOUNT_PASSWORD=
ANEWLUV_SITE_PREVIEW_ACCOUNTS_JSON=
ANEWLUV_SITE_PREVIEW_PROFILE_IDS=
ANEWLUV_SITE_APP_SCREENSHOT_BASE_URL=

# Frontend build-time switch. Use internal-iframes for public preview pages
# backed by /api/app-preview. Use screenshots for captured app screenshots or
# live-app-iframe only after the app has a readonly marketing embed session.
VITE_ANEWLUV_APP_PREVIEW_MODE=internal-iframes
VITE_ANEWLUV_LIVE_APP_EMBEDS=false
VITE_ANEWLUV_LIVE_HOME_EMBED=true
VITE_ANEWLUV_TIKTOK_URL=https://www.tiktok.com/@anewluv4
